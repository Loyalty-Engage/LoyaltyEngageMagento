<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework/ObjectManager/etc/config.xsd">
    <preference for="LoyaltyEngage\LoyaltyShop\Api\LoyaltyCartInterface"
        type="LoyaltyEngage\LoyaltyShop\Model\LoyaltyCart" />
    <preference for="LoyaltyEngage\LoyaltyShop\Api\Data\LoyaltyCartResponseInterface"
        type="LoyaltyEngage\LoyaltyShop\Model\LoyaltyCartResponse" />
    <preference for="LoyaltyEngage\LoyaltyShop\Api\LoyaltyCartItemsRemoveApiInterface"
        type="LoyaltyEngage\LoyaltyShop\Model\LoyaltyCartItemsRemoveAll" />
    <preference for="LoyaltyEngage\LoyaltyShop\Api\LoyaltyCartItemRemoveApiInterface"
        type="LoyaltyEngage\LoyaltyShop\Model\LoyaltyCartItemRemove" />
    <preference for="LoyaltyEngage\LoyaltyShop\Api\CustomerLoyaltyInterface"
        type="LoyaltyEngage\LoyaltyShop\Model\CustomerLoyalty" />
    <preference for="LoyaltyEngage\LoyaltyShop\Api\Data\CustomerLoyaltyUpdateResponseInterface"
        type="LoyaltyEngage\LoyaltyShop\Model\Data\CustomerLoyaltyUpdateResponse" />
    <virtualType name="Magento\Sales\Model\ResourceModel\Order\Grid"
        type="Magento\Sales\Model\ResourceModel\Grid">
        <arguments>
            <argument name="columns" xsi:type="array">
                <item name="loyalty_order_place" xsi:type="string">
                    sales_order.loyalty_order_place</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="Magento\Sales\Model\ResourceModel\Order\Grid"
        type="Magento\Sales\Model\ResourceModel\Grid">
        <arguments>
            <argument name="columns" xsi:type="array">
                <item name="loyalty_order_place_retrieve" xsi:type="string">
                    sales_order.loyalty_order_place_retrieve</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Magento\Customer\CustomerData\Customer">
        <plugin name="loyaltyshop_customer_data_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\CustomerDataPlugin" />
    </type>
    
    <type name="Magento\Checkout\Block\Cart\Item\Renderer">
        <plugin name="loyaltyshop_cart_item_renderer_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\CheckoutCartItemRendererPlugin"
            sortOrder="100" />
    </type>
    
    <type name="Magento\CatalogInventory\Model\Quote\Item\QuantityValidator">
        <plugin name="loyaltyshop_quote_item_qty_validator_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\QuoteItemQtyValidatorPlugin" />
    </type>
    
    <type name="Magento\Checkout\Controller\Cart\UpdatePost">
        <plugin name="loyaltyshop_cart_update_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\CartUpdatePlugin"
            sortOrder="10" />
    </type>
    
    <type name="Magento\Shipping\Model\Rate\CarrierResult">
        <plugin name="loyaltyshop_shipping_method_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\ShippingMethodPlugin"
            sortOrder="100" />
    </type>
    
    <!-- Configure message queue consumers to run automatically -->
    <type name="Magento\Framework\MessageQueue\Consumer\Config\ConsumerConfigItem">
        <arguments>
            <argument name="consumerConfig" xsi:type="array">
                <item name="loyaltyshop_purchase_event_consumer" xsi:type="array">
                    <item name="autoStart" xsi:type="boolean">true</item>
                </item>
                <item name="loyaltyshop_return_event_consumer" xsi:type="array">
                    <item name="autoStart" xsi:type="boolean">true</item>
                </item>
                <item name="loyaltyshop_free_product_purchase_event_consumer" xsi:type="array">
                    <item name="autoStart" xsi:type="boolean">true</item>
                </item>
                <item name="loyaltyshop_free_product_remove_event_consumer" xsi:type="array">
                    <item name="autoStart" xsi:type="boolean">true</item>
                </item>
                <item name="loyaltyshop_review_event_consumer" xsi:type="array">
                    <item name="autoStart" xsi:type="boolean">true</item>
                </item>
            </argument>
        </arguments>
    </type>
    
    <!-- Add loyalty conditions to catalog price rules -->
    <type name="Magento\CatalogRule\Model\Rule\Condition\Combine">
        <plugin name="loyaltyshop_catalog_rule_condition_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\CatalogRule\Model\Rule\Condition\CombinePlugin"
            sortOrder="100" />
    </type>
    
    <!-- Add loyalty conditions to cart price rules -->
    <type name="Magento\SalesRule\Model\Rule\Condition\Combine">
        <plugin name="loyaltyshop_sales_rule_condition_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\SalesRule\Model\Rule\Condition\CombinePlugin"
            sortOrder="100" />
    </type>
    
    <!-- Target shipping carriers directly -->
    <type name="Magento\OfflineShipping\Model\Carrier\Tablerate">
        <plugin name="loyaltyshop_tablerate_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\Shipping\TableratePlugin"
            sortOrder="100" />
    </type>
    
    <type name="Magento\OfflineShipping\Model\Carrier\Flatrate">
        <plugin name="loyaltyshop_flatrate_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\Shipping\FlatratePlugin"
            sortOrder="100" />
    </type>
    
    <!-- Configure LoyaltyCart dependencies for rule reuse -->
    <type name="LoyaltyEngage\LoyaltyShop\Model\LoyaltyCart">
        <arguments>
            <argument name="ruleCollectionFactory" xsi:type="object">Magento\SalesRule\Model\ResourceModel\Rule\CollectionFactory</argument>
            <argument name="couponFactory" xsi:type="object">Magento\SalesRule\Model\CouponFactory</argument>
            <argument name="customerGroupRepository" xsi:type="object">Magento\Customer\Api\GroupRepositoryInterface</argument>
            <argument name="searchCriteriaBuilderFactory" xsi:type="object">Magento\Framework\Api\SearchCriteriaBuilderFactory</argument>
        </arguments>
    </type>
    
    <!-- REST API Authentication Plugin - validates Basic Auth for LoyaltyEngage endpoints -->
    <type name="Magento\Webapi\Controller\Rest">
        <plugin name="loyaltyshop_webapi_authentication_plugin"
            type="LoyaltyEngage\LoyaltyShop\Plugin\WebApi\AuthenticationPlugin"
            sortOrder="10" />
    </type>
</config>
