<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:Config/etc/config.xsd">
    <default>
        <loyalty>
            <general>
                <module_enable>1</module_enable>
                <loyalty_api_url>https://app.loyaltyengage.tech</loyalty_api_url>
                <tenant_id></tenant_id>
                <bearer_token></bearer_token>
                <cart_expiry_time>1</cart_expiry_time>
                <logger_enable>0</logger_enable>
                <debug_logging>0</debug_logging>
                <loyalty_order_place_retrieve>5</loyalty_order_place_retrieve>
                <queue_processing_frequency>*/5 * * * *</queue_processing_frequency>
                <minimum_order_value>0</minimum_order_value>
                <minimum_order_value_message><![CDATA[Your cart subtotal must be at least €{{minimum}} to add loyalty products. Current subtotal: €{{current}}]]></minimum_order_value_message>
                <minimum_order_value_bar_color>#e74c3c</minimum_order_value_bar_color>
                <minimum_order_value_text_color>#ffffff</minimum_order_value_text_color>
            </general>
        </loyalty>
        <consumers_runner>
            <consumers>
                <loyaltyshop_purchase_event_consumer>
                    <name>loyaltyshop_purchase_event_consumer</name>
                    <max_messages>0</max_messages>
                </loyaltyshop_purchase_event_consumer>
                <loyaltyshop_return_event_consumer>
                    <name>loyaltyshop_return_event_consumer</name>
                    <max_messages>0</max_messages>
                </loyaltyshop_return_event_consumer>
                <loyaltyshop_free_product_purchase_event_consumer>
                    <name>loyaltyshop_free_product_purchase_event_consumer</name>
                    <max_messages>0</max_messages>
                </loyaltyshop_free_product_purchase_event_consumer>
                <loyaltyshop_free_product_remove_event_consumer>
                    <name>loyaltyshop_free_product_remove_event_consumer</name>
                    <max_messages>0</max_messages>
                </loyaltyshop_free_product_remove_event_consumer>
            </consumers>
        </consumers_runner>
    </default>
</config>
